<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled"
    Background="Transparent">

    <Grid Padding="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   x:Uid="Settings_Title"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"
                   HorizontalAlignment="Left"/>

        <!-- Scrollable content area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

            <!-- Main content grid -->
                <Grid HorizontalAlignment="Left"
                  MaxWidth="520">
                <StackPanel Spacing="18"
                            HorizontalAlignment="Left">

                    <!-- Language -->
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Left">
                        <TextBlock x:Uid="Settings_Language"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"/>
                        <ComboBox x:Name="cboLanguage"
                                  MinWidth="240"
                                  MaxWidth="320"
                                  HorizontalAlignment="Left"
                                  SelectionChanged="CboLanguage_SelectionChanged"/>
                    </StackPanel>
                    
                    <!-- Extensions -->
                    <Expander
                        Width="520"
                        HorizontalAlignment="Left"
                        IsExpanded="False">

                        <Expander.Header>
                            <Grid
                                Padding="0,12,0,12"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Header icon -->
                                <FontIcon
                                    Grid.Column="0"
                                    Glyph="&#xEA86;"
                                    FontSize="16"
                                    VerticalAlignment="Center" />

                                <!-- Header text -->
                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="3">
                                    <TextBlock
                                        x:Uid="Settings_Extensions"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Left" />
                                    <TextBlock
                                        x:Uid="Settings_ExtensionsSubtext"
                                        FontSize="12"
                                        Opacity="0.75"
                                        TextWrapping="WrapWholeWords"
                                        HorizontalAlignment="Left" />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>

                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Plugins -->
                            <Grid Grid.Row="0"
                                  ColumnSpacing="16"
                                  Padding="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                               Spacing="4"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left">
                                    <TextBlock x:Uid="Settings_Plugins"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords"/>
                                    <TextBlock x:Uid="Settings_PluginsDescription"
                                               FontSize="12"
                                               Opacity="0.75"
                                               TextWrapping="WrapWholeWords"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Click="BtnPlugins_Click"
                                        Padding="12,8"
                                        CornerRadius="4"
                                        MinWidth="140"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Uid="Settings_ManagePlugins"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               TextWrapping="WrapWholeWords"/>
                                </Button>
                            </Grid>

                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="{ThemeResource ControlStrokeColorSecondaryBrush}"/>

                            <!-- Tools -->
                            <Grid Grid.Row="2"
                                  ColumnSpacing="16"
                                  Padding="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="4"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                    <TextBlock x:Uid="Settings_ToolScripts"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords"/>
                                    <TextBlock x:Uid="Settings_ToolScriptsDescription"
                                               FontSize="12"
                                               Opacity="0.75"
                                               TextWrapping="WrapWholeWords"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Click="BtnTools_Click"
                                        Padding="12,8"
                                        CornerRadius="4"
                                        MinWidth="140"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Uid="Settings_OpenToolsPage"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               TextWrapping="WrapWholeWords"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Expander>

                    <!-- About -->
                    <StackPanel Spacing="10"
                                HorizontalAlignment="Left">
                        <TextBlock x:Uid="Settings_About"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtVersion"
                                   FontSize="13"
                                   Opacity="0.9"/>
                        <TextBlock Text="by Belim"
                                   FontSize="12"
                                   Opacity="0.8"
                                   Margin="0,-4,0,0"/>

                        <HyperlinkButton Click="BtnGitHub_Click"
                                         Padding="0"
                                         HorizontalAlignment="Left">
                            <TextBlock Text="GitHub" FontSize="13"/>
                        </HyperlinkButton>

                        <HyperlinkButton Click="BtnUpdates_Click"
                                         Padding="0"
                                         HorizontalAlignment="Left">
                            <TextBlock x:Uid="Settings_CheckUpdates" FontSize="13"/>
                        </HyperlinkButton>

                        <HyperlinkButton Click="BtnHelp_Click"
                                         Padding="0"
                                         HorizontalAlignment="Left">
                            <TextBlock x:Uid="MenuHelp" FontSize="13"/>
                        </HyperlinkButton>

                        <Button Click="BtnFeedback_Click"
                                HorizontalAlignment="Left"
                                MinWidth="180"
                                Padding="10,8"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                            <TextBlock x:Uid="Settings_Feedback"
                                       FontSize="13"
                                       TextWrapping="WrapWholeWords"/>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>