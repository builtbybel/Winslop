<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Winslop.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ext="using:Winslop.Tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Filter + Tool list -->
        <Grid Grid.Column="0" Margin="0,0,6,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Filter combo (e.g., by category) -->
            
            <ComboBox x:Name="comboFilter" Grid.Row="0" HorizontalAlignment="Stretch"
            x:Uid="ComboFilter" FontSize="12" Height="30"
            Margin="0,0,0,4"
            SelectionChanged="comboFilter_SelectionChanged" />

            <Border Grid.Row="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0" CornerRadius="4" Padding="2">
                <ListView x:Name="listTools" SelectionMode="Single"
                          SelectionChanged="listTools_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="ext:ToolsDefinition">
                            <TextBlock Text="{x:Bind Title}" FontSize="12" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <TextBlock x:Name="lblStatus" Grid.Row="2" FontSize="11" Margin="0,4,0,0"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </Grid>

        <!-- Right: Details panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="panelDetails" Spacing="6">

                <!-- Icon + Title -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="lblIcon" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="lblTitle" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Description -->
                <TextBlock x:Name="lblDescription" FontSize="12" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <!-- Options combo (hidden when no options) -->
                <ComboBox x:Name="comboOptions" HorizontalAlignment="Stretch"
                          Visibility="Collapsed" x:Uid="ComboOptions" />

                <!-- Input textbox (hidden when not supported) -->
                <TextBox x:Name="textInput" HorizontalAlignment="Stretch"
                         Visibility="Collapsed"
                         x:Uid="TextInput" />

                <!-- Powered-by link (hidden when empty) -->
                <HyperlinkButton x:Name="linkPoweredBy" Visibility="Collapsed"
                                 FontSize="11" Padding="0"
                                 Click="linkPoweredBy_Click" />

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button x:Name="btnRun" x:Uid="BtnRun" Click="btnRun_Click"
                            Visibility="Collapsed" FontSize="11" Padding="12,4" />
                    <Button x:Name="btnUninstall" x:Uid="BtnToolUninstall" Click="btnUninstall_Click"
                            Visibility="Collapsed" FontSize="11" Padding="12,4" />
                    <Button x:Name="btnOpenFolder" Content="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                            Click="btnOpenFolder_Click" FontSize="11" Padding="8,4"
                            x:Uid="BtnOpenFolder" />
                </StackPanel>

                <!-- Status text -->
                <TextBlock x:Name="lblDetailStatus" FontSize="11"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <!-- Progress ring (hidden by default) -->
                <ProgressRing x:Name="progressRing" IsActive="False"
                              Width="24" Height="24" HorizontalAlignment="Left" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
